# Example environment variables for NaviOwl
# Copy this file to `.env` and fill in the values before running.

# OpenAI API key (required for chat functionality)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Comma-separated list of allowed CORS origins for the API
# e.g. ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
